{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "manga-lens-admin",
  "main": "workers/admin.js",
  "compatibility_date": "2026-03-22",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "manga-lens-admin"
    }
  ]
}
